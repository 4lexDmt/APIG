# Server
PORT=8080
ENV=development
LOG_LEVEL=debug

# PostgreSQL
DATABASE_URL=postgresql://routeiq:routeiq@localhost:5432/routeiq?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=20

# OpenAI (Sprint 1 only)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Auth
JWT_SECRET=change-me-in-production
API_KEY_SALT=change-me-in-production

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=routeiq-gateway
